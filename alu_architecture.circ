    </comp>
    <comp lib="0" loc="(540,180)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="remainder"/>
      <a name="width" val="8"/>
    </comp>
    <comp lib="0" loc="(540,220)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="done"/>
    </comp>

    <wire from="(80,80)" to="(280,80)"/>
    <wire from="(280,80)" to="(280,130)"/>
    <wire from="(280,130)" to="(320,130)"/>

    <wire from="(80,140)" to="(280,140)"/>
    <wire from="(280,140)" to="(280,150)"/>
    <wire from="(280,150)" to="(320,150)"/>

    <wire from="(370,140)" to="(540,140)"/>
    <wire from="(370,160)" to="(420,160)"/>
    <wire from="(420,160)" to="(420,180)"/>
    <wire from="(420,180)" to="(540,180)"/>

    <wire from="(80,200)" to="(540,220)"/>
  </circuit>

  <!-- ============================================================== -->
  <!-- Sub-circuit: CONTROL_UNIT (FSM: IDLE/LOAD/EXEC/DONE)           -->
  <!-- ============================================================== -->
  <circuit name="CONTROL_UNIT">
    <a name="appearance" val="logisim_evolution"/>
    <a name="circuit" val="CONTROL_UNIT"/>
    <a name="circuitnamedboxfixedsize" val="true"/>
    <a name="simulationFrequency" val="1.0"/>

    <comp lib="0" loc="(80,80)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="clk"/>
    </comp>
    <comp lib="0" loc="(80,120)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="rst"/>
    </comp>
    <comp lib="0" loc="(80,160)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="start"/>
    </comp>
    <comp lib="0" loc="(80,200)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="exec_done"/>
    </comp>
    <comp lib="0" loc="(80,240)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="exec_busy"/>
    </comp>

    <!-- 2-bit state register (placeholder representation) -->
    <comp lib="4" loc="(320,160)" name="Register">
      <a name="appearance" val="logisim_evolution"/>
      <a name="label" val="STATE"/>
      <a name="width" val="2"/>
    </comp>

    <comp lib="0" loc="(540,120)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="load_en"/>
    </comp>
    <comp lib="0" loc="(540,180)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="exec_start"/>
    </comp>
    <comp lib="0" loc="(540,240)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="done"/>
    </comp>

    <wire from="(80,80)" to="(320,80)"/>
    <wire from="(320,80)" to="(320,140)"/>

    <wire from="(80,120)" to="(290,120)"/>
    <wire from="(290,120)" to="(290,170)"/>
    <wire from="(290,170)" to="(320,170)"/>

    <wire from="(80,160)" to="(540,180)"/>
    <wire from="(80,200)" to="(540,240)"/>
    <wire from="(80,240)" to="(540,120)"/>
  </circuit>

  <!-- ============================================================== -->
  <!-- Sub-circuit: REGISTER_8BIT                                     -->
  <!-- ============================================================== -->
  <circuit name="REGISTER_8BIT">
    <a name="appearance" val="logisim_evolution"/>
    <a name="circuit" val="REGISTER_8BIT"/>
    <a name="circuitnamedboxfixedsize" val="true"/>
    <a name="simulationFrequency" val="1.0"/>

    <comp lib="0" loc="(80,80)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="data_in"/>
      <a name="width" val="8"/>
    </comp>
    <comp lib="0" loc="(80,140)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="load_en"/>
    </comp>
    <comp lib="0" loc="(80,180)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="clk"/>
    </comp>
    <comp lib="0" loc="(80,220)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="rst"/>
    </comp>

    <comp lib="4" loc="(300,120)" name="Register">
      <a name="appearance" val="logisim_evolution"/>
      <a name="label" val="REG"/>
      <a name="width" val="8"/>
    </comp>

    <comp lib="0" loc="(500,120)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="data_out"/>
      <a name="width" val="8"/>
    </comp>

    <wire from="(80,80)" to="(260,80)"/>
    <wire from="(260,80)" to="(260,110)"/>
    <wire from="(260,110)" to="(300,110)"/>

    <wire from="(80,180)" to="(300,180)"/>
    <wire from="(300,180)" to="(300,140)"/>

    <wire from="(80,220)" to="(280,220)"/>
    <wire from="(280,220)" to="(280,150)"/>
    <wire from="(280,150)" to="(300,150)"/>

    <wire from="(80,140)" to="(270,140)"/>
    <wire from="(270,140)" to="(270,130)"/>
    <wire from="(270,130)" to="(300,130)"/>

    <wire from="(350,110)" to="(500,120)"/>
  </circuit>

  <!-- ============================================================== -->
  <!-- Top circuit: ALU_TOP                                           -->
  <!-- Mirrors the diagram: opcode + A_raw + B_raw + start ->         -->
  <!-- registers -> add/sub | mul | div -> 4:1 mux -> result          -->
  <!-- ============================================================== -->
  <circuit name="ALU_TOP">
    <a name="appearance" val="logisim_evolution"/>
    <a name="circuit" val="ALU_TOP"/>
    <a name="circuitnamedboxfixedsize" val="true"/>
    <a name="simulationFrequency" val="1.0"/>

    <!-- Title -->
    <comp lib="8" loc="(400,40)" name="Text">
      <a name="text" val="Structural 8-bit ALU (Top-Level)"/>
      <a name="font" val="SansSerif bold 16"/>
    </comp>

    <!-- ============== Inputs (left side) ============== -->
    <comp lib="0" loc="(80,120)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="clk"/>
    </comp>
    <comp lib="0" loc="(80,160)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="rst"/>
    </comp>
    <comp lib="0" loc="(80,200)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="start"/>
    </comp>
    <comp lib="0" loc="(80,260)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="opcode"/>
      <a name="width" val="2"/>
    </comp>
    <comp lib="0" loc="(80,340)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="A_raw"/>
      <a name="width" val="8"/>
    </comp>
    <comp lib="0" loc="(80,420)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="east"/>
      <a name="label" val="B_raw"/>
      <a name="width" val="8"/>
    </comp>

    <!-- ============== Control Unit ============== -->
    <comp lib="8" loc="(220,90)" name="Text">
      <a name="text" val="Control Unit (FSM)"/>
      <a name="font" val="SansSerif bold 12"/>
    </comp>
    <comp loc="(280,180)" name="CONTROL_UNIT"/>

    <!-- ============== Operand registers ============== -->
    <comp lib="8" loc="(220,300)" name="Text">
      <a name="text" val="Operand Registers"/>
      <a name="font" val="SansSerif bold 12"/>
    </comp>
    <comp loc="(280,360)" name="REGISTER_8BIT"/>
    <comp loc="(280,440)" name="REGISTER_8BIT"/>

    <!-- ============== Opcode decoder (splitter) ============== -->
    <comp lib="0" loc="(180,260)" name="Splitter">
      <a name="appear" val="right"/>
      <a name="facing" val="east"/>
      <a name="fanout" val="2"/>
      <a name="incoming" val="2"/>
    </comp>

    <!-- ============== Arithmetic Engines ============== -->
    <comp lib="8" loc="(560,90)" name="Text">
      <a name="text" val="Arithmetic Engines"/>
      <a name="font" val="SansSerif bold 12"/>
    </comp>

    <comp loc="(540,180)" name="ADDER_SUBTRACTOR"/>
    <comp loc="(540,320)" name="BOOTH_MULTIPLIER"/>
    <comp loc="(540,460)" name="RADIX2_DIVIDER"/>

    <comp lib="8" loc="(540,170)" name="Text">
      <a name="text" val="ADD/SUB"/>
    </comp>
    <comp lib="8" loc="(540,310)" name="Text">
      <a name="text" val="MULTIPLIER"/>
    </comp>
    <comp lib="8" loc="(540,450)" name="Text">
      <a name="text" val="DIVIDER"/>
    </comp>

    <!-- ============== Result MUX (4:1 16-bit) ============== -->
    <comp lib="8" loc="(820,90)" name="Text">
      <a name="text" val="Result MUX"/>
      <a name="font" val="SansSerif bold 12"/>
    </comp>
    <comp lib="2" loc="(820,300)" name="Multiplexer">
      <a name="enable" val="false"/>
      <a name="select" val="2"/>
      <a name="width" val="16"/>
    </comp>

    <!-- ============== Outputs (right side) ============== -->
    <comp lib="0" loc="(980,300)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="result"/>
      <a name="width" val="16"/>
    </comp>
    <comp lib="0" loc="(980,200)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="carry_out"/>
    </comp>
    <comp lib="0" loc="(980,240)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="overflow"/>
    </comp>
    <comp lib="0" loc="(980,400)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="done"/>
    </comp>

    <!-- ===== Wires: signal routing (illustrative top-level layout) ===== -->
    <!-- clk/rst/start to control unit -->
    <wire from="(80,120)" to="(280,120)"/>
    <wire from="(80,160)" to="(280,160)"/>
    <wire from="(80,200)" to="(280,200)"/>

    <!-- A_raw / B_raw to operand registers -->
    <wire from="(80,340)" to="(280,340)"/>
    <wire from="(80,420)" to="(280,420)"/>

    <!-- Operand registers to engines (illustrative bus lines) -->
    <wire from="(380,360)" to="(440,360)"/>
    <wire from="(440,360)" to="(440,180)"/>
    <wire from="(440,180)" to="(540,180)"/>

    <wire from="(380,440)" to="(460,440)"/>
    <wire from="(460,440)" to="(460,200)"/>
    <wire from="(460,200)" to="(540,200)"/>

    <wire from="(380,360)" to="(440,360)"/>
    <wire from="(440,360)" to="(440,320)"/>
    <wire from="(440,320)" to="(540,320)"/>

    <wire from="(380,440)" to="(460,460)"/>
    <wire from="(460,460)" to="(540,460)"/>

    <!-- Engines to MUX inputs -->
    <wire from="(640,180)" to="(700,180)"/>
    <wire from="(700,180)" to="(700,260)"/>
    <wire from="(700,260)" to="(820,260)"/>

    <wire from="(640,320)" to="(720,320)"/>
    <wire from="(720,320)" to="(720,290)"/>
    <wire from="(720,290)" to="(820,290)"/>

    <wire from="(640,460)" to="(740,460)"/>
    <wire from="(740,460)" to="(740,330)"/>
    <wire from="(740,330)" to="(820,330)"/>

    <!-- Opcode to MUX select -->
    <wire from="(80,260)" to="(820,260)"/>

    <!-- MUX out to result -->
    <wire from="(870,300)" to="(980,300)"/>

    <!-- Status outputs -->
    <wire from="(640,200)" to="(980,200)"/>
    <wire from="(640,210)" to="(980,240)"/>

    <!-- Done from control unit -->
    <wire from="(380,180)" to="(980,400)"/>

  </circuit>
</project>
