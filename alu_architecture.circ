    <comp lib="0" loc="(540,140)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="product_lo"/>
      <a name="width" val="8"/>
    </comp>
    <comp lib="0" loc="(540,180)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="product_hi"/>
      <a name="width" val="8"/>
    </comp>
    <comp lib="0" loc="(540,220)" name="Pin">
      <a name="appearance" val="NewPins"/>
      <a name="facing" val="west"/>
      <a name="output" val="true"/>
      <a name="label" val="done"/>
    </comp>

    <wire from="(80,80)" to="(280,80)"/>
    <wire from="(280,80)" to="(280,130)"/>
    <wire from="(280,130)" to="(320,130)"/>

    <wire from="(80,140)" to="(280,140)"/>
    <wire from="(280,140)" to="(280,150)"/>
    <wire from="(280,150)" to="(320,150)"/>

    <wire from="(370,140)" to="(540,140)"/>
    <wire from="(370,160)" to="(420,160)"/>
    <wire from="(420,160)" to="(420,180)"/>
    <wire from="(420,180)" to="(540,180)"/>

    <wire from="(80,200)" to="(540,220)"/>
  </circuit>

